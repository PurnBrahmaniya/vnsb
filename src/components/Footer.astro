---
// src/layouts/BaseLayout.astro

// 1. IMPORT YOUR COMPONENTS HERE
import Nav from '../components/Nav.astro';

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Kalam:wght@400;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-50 text-gray-800 font-sans antialiased flex flex-col min-h-screen">
    
    <footer class="bg-white pt-20 pb-10 border-t border-gray-100 mt-auto">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
            <div class="col-span-1 md:col-span-1">
                <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-pastelPink rounded-xl flex items-center justify-center text-darkBlue p-1.5">
                    <svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
                        <path d="M10 112h100" stroke-width="2.5" />
                        <path d="M14 107h92" />
                        <path d="M18 102h84" />

                        <path d="M22 102v-12h14v12" />
                        <path d="M20 96h18" />
    
                        <path d="M84 102v-12h14v12" />
                        <path d="M82 96h18" />

                        <path d="M25 90V36h8v54h-8Z" fill="currentColor" fill-opacity="0.03" />
                        <path d="M23 80h12M23 68h12M23 56h12M23 44h12" stroke-width="1.5" />
                        <path d="M23 36h12l3-6H20l3 6Z" />

                        <path d="M87 90V36h8v54h-8Z" fill="currentColor" fill-opacity="0.03" />
                        <path d="M85 80h12M85 68h12M85 56h12M85 44h12" stroke-width="1.5" />
                        <path d="M85 36h12l3-6H82l3 6Z" />

                        <path d="M33 55C45 34 75 34 87 55" stroke-width="2" />
                        <path d="M35 59C46 39 74 39 85 59" stroke-width="1" stroke-dasharray="1 3" />
                        <path d="M60 34v10l2-2-2 4-2-4 2 2" stroke-width="1.5" />

                        <path d="M16 30h88v4H16z" fill="currentColor" fill-opacity="0.05" />

                        <path d="M20 22h80v4H20z" />
                        <path d="M24 26v4M36 26v4M48 26v4M60 26v4M72 26v4M84 26v4M96 26v4" stroke-width="1.5" />

                        <path d="M14 14h92v4H14z" fill="currentColor" fill-opacity="0.1" />
                        <path d="M18 18v4M30 18v4M42 18v4M54 18v4M66 18v4M78 18v4M90 18v4" stroke-width="1.5" />

                        <path d="M54 14l6-10 6 10H54Z" fill="currentColor" fill-opacity="0.1" />
                        <path d="M60 4V1" />
                        <path d="M26 14l4-6 4 6H26Z" />
                        <path d="M30 8V6" />
                        <path d="M86 14l4-6 4 6H86Z" />
                        <path d="M90 8V6" />
    
                        <path d="M16 14l2-4 2 4M100 14l2-4 2 4" />
                    </svg>
                </div>
                <a href="/" class="text-2xl font-bold tracking-tight text-darkBlue">VNSB</a>
            </div>
                <p class="text-gray-500 text-sm leading-relaxed">Empowering the next generation of creative thinkers and innovators through world-class education.</p>
            </div>
            <div>
                <h4 class="text-darkBlue font-bold mb-6">Quick Links</h4>
                <ul class="space-y-4 text-sm text-gray-500">
                    <li><a href="/courses" class="hover:text-darkBlue transition-colors">All Courses</a></li>
                    <li><a href="/faculty" class="hover:text-darkBlue transition-colors">Our Faculty</a></li>
                    <li><a href="/rankings" class="hover:text-darkBlue transition-colors">Achievements</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-darkBlue font-bold mb-6">Contact Us</h4>
                <ul class="space-y-4 text-sm text-gray-500">
                    <li>📍 123 Academic Way</li>
                    <li>📞 +1 (234) 567-890</li>
                    <li>✉ hello@doodleuni.edu</li>
                </ul>
            </div>
            <div>
                <h4 class="text-darkBlue font-bold mb-6">Follow Us</h4>
                <div class="flex gap-4">
                    <a href="#" class="w-10 h-10 border border-gray-200 rounded-full flex items-center justify-center text-gray-500 hover:bg-gray-50">IG</a>
                    <a href="#" class="w-10 h-10 border border-gray-200 rounded-full flex items-center justify-center text-gray-500 hover:bg-gray-50">TW</a>
                </div>
            </div>
        </div>
        <div class="text-center text-sm text-gray-400 border-t border-gray-100 pt-8">
            © 2026 Doodle University. All rights reserved.
        </div>
    </footer>
</body>
</html>