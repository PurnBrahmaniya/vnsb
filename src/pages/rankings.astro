---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="DoodleUni - Rankings">
    <section class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
            <div class="inline-block bg-pastelGreen text-green-900 px-4 py-1.5 rounded-full text-sm font-bold mb-6 rotate-[2deg]">Our Pride & Glory</div>
            <h2 class="text-4xl md:text-5xl font-extrabold text-darkBlue mb-4">Rankings & Achievements</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
             <div class="bg-white p-8 rounded-3xl shadow-sm">
                <h3 class="text-4xl font-extrabold text-darkBlue mb-2">#1</h3>
                <h4 class="text-lg font-bold text-darkBlue mb-2">National Academic Excellence</h4>
                <p class="text-gray-500 text-sm">Ranked top university for academic rigor and student success.</p>
            </div>
             <div class="bg-white p-8 rounded-3xl shadow-sm">
                <h3 class="text-4xl font-extrabold text-darkBlue mb-2">#3</h3>
                <h4 class="text-lg font-bold text-darkBlue mb-2">Innovation & Research</h4>
                <p class="text-gray-500 text-sm">Leading the country in breakthrough research and patent filings.</p>
            </div>
             <div class="bg-white p-8 rounded-3xl shadow-sm">
                <h3 class="text-4xl font-extrabold text-darkBlue mb-2">#1</h3>
                <h4 class="text-lg font-bold text-darkBlue mb-2">Employer Reputation</h4>
                <p class="text-gray-500 text-sm">Highest placement rate with top-tier global companies.</p>
            </div>
             <div class="bg-white p-8 rounded-3xl shadow-sm">
                <h3 class="text-4xl font-extrabold text-darkBlue mb-2">98%</h3>
                <h4 class="text-lg font-bold text-darkBlue mb-2">Student Satisfaction</h4>
                <p class="text-gray-500 text-sm">Consistently voted as the most student-friendly campus.</p>
            </div>
        </div>
    </section>
</BaseLayout>