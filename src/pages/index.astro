---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="VNSB - Home">
    
    <section class="max-w-5xl mx-auto px-6 text-center mb-20">
        <div class="inline-block bg-pastelGreen text-green-900 px-5 py-2 rounded-full font-bold mb-6 tracking-wide rotate-[-2deg] font-['Kalam',cursive] text-lg shadow-sm">
            Welcome to Doodle University
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold text-darkBlue leading-tight mb-6 tracking-tighter">
            Where <span class="text-transparent bg-clip-text bg-gradient-to-r from-pastelPink to-pastelPurple">Creativity</span><br>
            Meets Academic Excellence
        </h1>
        <p class="text-lg text-gray-500 mb-10 max-w-2xl mx-auto">Join a community of forward-thinkers, dreamers, and makers. Discover your potential in an environment designed to inspire.</p>
        
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/courses" class="bg-darkBlue text-white px-8 py-4 rounded-full font-semibold hover:bg-gray-800 transition-all flex items-center justify-center gap-2 shadow-md">
                Explore Courses <span>→</span>
            </a>
            <a href="/about" class="bg-white text-darkBlue px-8 py-4 rounded-full font-semibold border border-gray-200 hover:border-gray-300 transition-all shadow-sm">
                Learn More
            </a>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 mb-24">
        <div class="w-full h-64 md:h-[500px] bg-gray-200 rounded-[2.5rem] overflow-hidden shadow-sm flex items-center justify-center">
            <span class="text-gray-400 font-medium">[ Campus Wide Image Placeholder ]</span>
        </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 mb-32">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <div class="bg-white p-10 rounded-[2rem] shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] text-center border border-gray-50">
            <div class="w-14 h-14 bg-yellow-50 text-yellow-500 rounded-2xl mx-auto flex items-center justify-center mb-6">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
            </div>
            <h3 class="text-4xl font-extrabold text-darkBlue mb-2">#1</h3>
            <p class="text-gray-500 text-sm font-medium">Top Ranking</p>
        </div>

        <div class="bg-white p-10 rounded-[2rem] shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] text-center border border-gray-50">
        <div class="w-14 h-14 bg-blue-50 text-blue-500 rounded-2xl mx-auto flex items-center justify-center mb-6">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
        </div>
            <h3 class="text-4xl font-extrabold text-darkBlue mb-2">15k+</h3>
            <p class="text-gray-500 text-sm font-medium">Total Students</p>
        </div>

        <div class="bg-white p-10 rounded-[2rem] shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] text-center border border-gray-50">
            <div class="w-14 h-14 bg-green-50 text-green-500 rounded-2xl mx-auto flex items-center justify-center mb-6">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-4xl font-extrabold text-darkBlue mb-2">80+</h3>
            <p class="text-gray-500 text-sm font-medium">Countries</p>
        </div>

        <div class="bg-white p-10 rounded-[2rem] shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] text-center border border-gray-50">
            <div class="w-14 h-14 bg-purple-50 text-purple-500 rounded-2xl mx-auto flex items-center justify-center mb-6">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            </div>
            <h3 class="text-4xl font-extrabold text-darkBlue mb-2">200+</h3>
            <p class="text-gray-500 text-sm font-medium">Courses</p>
        </div>

        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 flex flex-col lg:flex-row items-center gap-16">
        <div class="lg:w-1/2">
            <div class="inline-block bg-pastelYellow text-yellow-900 px-5 py-2 rounded-full font-bold mb-6 rotate-[-2deg] font-['Kalam',cursive] text-lg shadow-sm">
                Why Choose Us?
            </div>
            <h2 class="text-4xl md:text-5xl font-extrabold text-darkBlue mb-10 leading-tight">A Modern Campus for Future Innovators</h2>
            
            <div class="space-y-8">
                <div class="flex gap-4">
                    <div class="w-8 h-8 shrink-0 bg-darkBlue text-white rounded-full flex items-center justify-center font-bold text-sm">1</div>
                    <div>
                        <h4 class="text-xl font-bold text-darkBlue mb-2">Interactive Learning</h4>
                        <p class="text-gray-500">State-of-the-art labs and interactive lecture halls designed for collaborative work.</p>
                    </div>
                </div>
                <div class="flex gap-4">
                    <div class="w-8 h-8 shrink-0 bg-darkBlue text-white rounded-full flex items-center justify-center font-bold text-sm">2</div>
                    <div>
                        <h4 class="text-xl font-bold text-darkBlue mb-2">Expert Mentorship</h4>
                        <p class="text-gray-500">Learn from industry leaders and acclaimed professors who care about your growth.</p>
                    </div>
                </div>
                <div class="flex gap-4">
                    <div class="w-8 h-8 shrink-0 bg-darkBlue text-white rounded-full flex items-center justify-center font-bold text-sm">3</div>
                    <div>
                        <h4 class="text-xl font-bold text-darkBlue mb-2">Global Opportunities</h4>
                        <p class="text-gray-500">Exchange programs and internships with top companies around the world.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="lg:w-1/2 w-full h-[500px] bg-gray-200 rounded-[2.5rem] flex items-center justify-center shadow-sm">
             <span class="text-gray-400 font-medium">[ Feature Image Placeholder ]</span>
        </div>
    </section>

</BaseLayout>