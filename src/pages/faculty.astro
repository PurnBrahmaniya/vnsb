---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="DoodleUni - Faculty">
    <section class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-extrabold text-darkBlue mb-4">Our Faculty</h2>
            <p class="text-gray-500 max-w-2xl mx-auto">Meet the brilliant minds behind our academic excellence.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 text-center">
            <div class="bg-white p-8 rounded-3xl shadow-sm">
                <div class="w-32 h-32 mx-auto bg-gray-200 rounded-[2rem] mb-6"></div>
                <h3 class="text-xl font-bold text-darkBlue">Dr. Sarah Mitchell</h3>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Head of Computer Science</p>
                <span class="inline-block bg-gray-50 text-gray-500 text-xs px-3 py-1 rounded-full mb-4">Science & Tech</span>
            </div>
            <div class="bg-white p-8 rounded-3xl shadow-sm">
                <div class="w-32 h-32 mx-auto bg-gray-200 rounded-[2rem] mb-6"></div>
                <h3 class="text-xl font-bold text-darkBlue">Prof. David Chen</h3>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Professor of Design</p>
                <span class="inline-block bg-gray-50 text-gray-500 text-xs px-3 py-1 rounded-full mb-4">Creative Arts</span>
            </div>
            <div class="bg-white p-8 rounded-3xl shadow-sm">
                <div class="w-32 h-32 mx-auto bg-gray-200 rounded-[2rem] mb-6"></div>
                <h3 class="text-xl font-bold text-darkBlue">Dr. Elena Rodriguez</h3>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Dean of Business</p>
                <span class="inline-block bg-gray-50 text-gray-500 text-xs px-3 py-1 rounded-full mb-4">Business School</span>
            </div>
            <div class="bg-white p-8 rounded-3xl shadow-sm">
                <div class="w-32 h-32 mx-auto bg-gray-200 rounded-[2rem] mb-6"></div>
                <h3 class="text-xl font-bold text-darkBlue">Prof. James Wilson</h3>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Senior Lecturer</p>
                <span class="inline-block bg-gray-50 text-gray-500 text-xs px-3 py-1 rounded-full mb-4">Engineering</span>
            </div>
        </div>
    </section>
</BaseLayout>