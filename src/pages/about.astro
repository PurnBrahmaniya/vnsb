---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="DoodleUni - About Us">
    <section class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col lg:flex-row gap-12 mb-16 items-center">
            <div class="lg:w-1/2 h-[400px] bg-gray-200 rounded-[3rem] shadow-sm flex items-center justify-center">
                 <span class="text-gray-400 font-medium">[ About Image Placeholder ]</span>
            </div>
            <div class="lg:w-1/2 flex flex-col justify-center">
                <h2 class="text-4xl md:text-5xl font-extrabold text-darkBlue mb-6">Rooted in Tradition, Aiming for the Future</h2>
                <p class="text-gray-500 mb-4">What started as a small art and design school has evolved into a comprehensive university. Over the decades, we've remained true to our "doodle" philosophy.</p>
                <p class="text-gray-500">Today, we host over 15,000 students across 12 departments, blending technology, arts, and business in ways that redefine the future of education.</p>
            </div>
        </div>
        <div class="text-center">
             <h3 class="text-2xl font-extrabold text-darkBlue mb-8">More Than Just Academics</h3>
             <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                 <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-50"><h4 class="text-2xl font-bold text-darkBlue">50+</h4><p class="text-xs text-gray-400">Student Clubs</p></div>
                 <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-50"><h4 class="text-2xl font-bold text-darkBlue">12</h4><p class="text-xs text-gray-400">Creative Hubs</p></div>
                 <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-50"><h4 class="text-2xl font-bold text-darkBlue">24/7</h4><p class="text-xs text-gray-400">Study Spaces</p></div>
                 <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-50"><h4 class="text-2xl font-bold text-darkBlue">40 Acres</h4><p class="text-xs text-gray-400">Green Campus</p></div>
             </div>
        </div>
    </section>
</BaseLayout>