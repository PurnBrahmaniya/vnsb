---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="VNSB - Courses">
    <section class="max-w-7xl mx-auto px-6 mb-24">
        <div class="text-center mb-12">
            <h2 class="text-4xl md:text-5xl font-extrabold text-darkBlue mb-4">Our Courses</h2>
            <p class="text-gray-500 max-w-2xl mx-auto">Explore our diverse range of academic programs designed to prepare you for a successful career in your chosen field.</p>
        </div>
        
        <div class="flex flex-col lg:flex-row justify-center items-center gap-4 mb-12">
            <div class="relative w-full lg:w-auto flex-grow max-w-md">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <input type="text" id="searchInput" placeholder="Search courses..." class="w-full pl-11 pr-4 py-3 rounded-full border border-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 bg-white shadow-sm text-sm text-gray-700">
            </div>
            
            <div class="flex flex-wrap justify-center gap-2" id="filterContainer">
                <button class="filter-btn active px-6 py-3 bg-darkBlue text-white rounded-full font-semibold text-sm transition-colors shadow-sm" data-filter="all">All</button>
                <button class="filter-btn px-6 py-3 bg-gray-50 text-gray-600 rounded-full font-semibold text-sm hover:bg-gray-100 transition-colors shadow-sm" data-filter="Science & Tech">Science & Tech</button>
                <button class="filter-btn px-6 py-3 bg-gray-50 text-gray-600 rounded-full font-semibold text-sm hover:bg-gray-100 transition-colors shadow-sm" data-filter="Creative Arts">Creative Arts</button>
                <button class="filter-btn px-6 py-3 bg-gray-50 text-gray-600 rounded-full font-semibold text-sm hover:bg-gray-100 transition-colors shadow-sm" data-filter="Business">Business</button>
                <button class="filter-btn px-6 py-3 bg-gray-50 text-gray-600 rounded-full font-semibold text-sm hover:bg-gray-100 transition-colors shadow-sm" data-filter="Engineering">Engineering</button>
                <button class="filter-btn px-6 py-3 bg-gray-50 text-gray-600 rounded-full font-semibold text-sm hover:bg-gray-100 transition-colors shadow-sm" data-filter="Social Sciences">Social Sciences</button>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="courseGrid">
            
            <div class="course-card bg-white p-8 rounded-[2rem] shadow-sm border border-gray-100 flex flex-col h-full hover:-translate-y-1 transition-transform" data-category="Science & Tech">
                <div class="flex justify-between items-start mb-6">
                    <div class="text-gray-600">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14v7"/></svg>
                    </div>
                    <span class="text-xs font-bold bg-gray-50 text-gray-500 px-3 py-1.5 rounded-full uppercase tracking-wider">Science & Tech</span>
                </div>
                <h3 class="text-xl font-bold text-darkBlue mb-3">B.Sc. Computer Science</h3>
                <p class="text-gray-500 text-sm mb-8 flex-grow">Comprehensive study of computing, algorithms, and software engineering.</p>
                <div class="flex justify-between items-center pt-5 border-t border-gray-100 mt-auto">
                    <span class="text-sm font-medium text-gray-500 flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> 3 Years</span>
                    <a href="#" class="text-darkBlue font-bold text-sm hover:underline">Apply Now</a>
                </div>
            </div>
            
            <div class="course-card bg-white p-8 rounded-[2rem] shadow-sm border border-gray-100 flex flex-col h-full hover:-translate-y-1 transition-transform" data-category="Creative Arts">
                <div class="flex justify-between items-start mb-6">
                    <div class="text-gray-600">
                         <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14v7"/></svg>
                    </div>
                    <span class="text-xs font-bold bg-gray-50 text-gray-500 px-3 py-1.5 rounded-full uppercase tracking-wider">Creative Arts</span>
                </div>
                <h3 class="text-xl font-bold text-darkBlue mb-3">B.A. Graphic Design</h3>
                <p class="text-gray-500 text-sm mb-8 flex-grow">Focus on visual communication, branding, and digital media.</p>
                <div class="flex justify-between items-center pt-5 border-t border-gray-100 mt-auto">
                    <span class="text-sm font-medium text-gray-500 flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> 3 Years</span>
                    <a href="#" class="text-darkBlue font-bold text-sm hover:underline">Apply Now</a>
                </div>
            </div>

            <div class="course-card bg-white p-8 rounded-[2rem] shadow-sm border border-gray-100 flex flex-col h-full hover:-translate-y-1 transition-transform" data-category="Business">
                <div class="flex justify-between items-start mb-6">
                    <div class="text-gray-600">
                         <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14v7"/></svg>
                    </div>
                    <span class="text-xs font-bold bg-gray-50 text-gray-500 px-3 py-1.5 rounded-full uppercase tracking-wider">Business</span>
                </div>
                <h3 class="text-xl font-bold text-darkBlue mb-3">M.B.A. Innovation</h3>
                <p class="text-gray-500 text-sm mb-8 flex-grow">Advanced management strategies with a focus on entrepreneurship.</p>
                <div class="flex justify-between items-center pt-5 border-t border-gray-100 mt-auto">
                    <span class="text-sm font-medium text-gray-500 flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> 2 Years</span>
                    <a href="#" class="text-darkBlue font-bold text-sm hover:underline">Apply Now</a>
                </div>
            </div>

            <div class="course-card bg-white p-8 rounded-[2rem] shadow-sm border border-gray-100 flex flex-col h-full hover:-translate-y-1 transition-transform" data-category="Engineering">
                <div class="flex justify-between items-start mb-6">
                    <div class="text-gray-600">
                         <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14v7"/></svg>
                    </div>
                    <span class="text-xs font-bold bg-gray-50 text-gray-500 px-3 py-1.5 rounded-full uppercase tracking-wider">Engineering</span>
                </div>
                <h3 class="text-xl font-bold text-darkBlue mb-3">B.Tech. Robotics</h3>
                <p class="text-gray-500 text-sm mb-8 flex-grow">Integrating mechanical, electronic, and software systems.</p>
                <div class="flex justify-between items-center pt-5 border-t border-gray-100 mt-auto">
                    <span class="text-sm font-medium text-gray-500 flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> 4 Years</span>
                    <a href="#" class="text-darkBlue font-bold text-sm hover:underline">Apply Now</a>
                </div>
            </div>

            <div class="course-card bg-white p-8 rounded-[2rem] shadow-sm border border-gray-100 flex flex-col h-full hover:-translate-y-1 transition-transform" data-category="Social Sciences">
                <div class="flex justify-between items-start mb-6">
                    <div class="text-gray-600">
                         <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14v7"/></svg>
                    </div>
                    <span class="text-xs font-bold bg-gray-50 text-gray-500 px-3 py-1.5 rounded-full uppercase tracking-wider">Social Sciences</span>
                </div>
                <h3 class="text-xl font-bold text-darkBlue mb-3">B.A. Psychology</h3>
                <p class="text-gray-500 text-sm mb-8 flex-grow">Understanding human behavior, cognition, and mental health.</p>
                <div class="flex justify-between items-center pt-5 border-t border-gray-100 mt-auto">
                    <span class="text-sm font-medium text-gray-500 flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> 3 Years</span>
                    <a href="#" class="text-darkBlue font-bold text-sm hover:underline">Apply Now</a>
                </div>
            </div>

            <div class="course-card bg-white p-8 rounded-[2rem] shadow-sm border border-gray-100 flex flex-col h-full hover:-translate-y-1 transition-transform" data-category="Science & Tech">
                <div class="flex justify-between items-start mb-6">
                    <div class="text-gray-600">
                         <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 14v7"/></svg>
                    </div>
                    <span class="text-xs font-bold bg-gray-50 text-gray-500 px-3 py-1.5 rounded-full uppercase tracking-wider">Science & Tech</span>
                </div>
                <h3 class="text-xl font-bold text-darkBlue mb-3">M.Sc. Data Science</h3>
                <p class="text-gray-500 text-sm mb-8 flex-grow">Advanced analytics, machine learning, and big data processing.</p>
                <div class="flex justify-between items-center pt-5 border-t border-gray-100 mt-auto">
                    <span class="text-sm font-medium text-gray-500 flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> 2 Years</span>
                    <a href="#" class="text-darkBlue font-bold text-sm hover:underline">Apply Now</a>
                </div>
            </div>

        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const filterBtns = document.querySelectorAll('.filter-btn');
            const searchInput = document.getElementById('searchInput') as HTMLInputElement;
            const cards = document.querySelectorAll('.course-card');

            function filterCourses() {
                const searchTerm = searchInput.value.toLowerCase();
                const activeFilterElement = document.querySelector('.filter-btn.active') as HTMLElement;
                const activeFilter = activeFilterElement ? activeFilterElement.dataset.filter : 'all';

                cards.forEach(card => {
                    const htmlElement = card as HTMLElement;
                    const title = htmlElement.querySelector('h3')?.textContent?.toLowerCase() || '';
                    const category = htmlElement.dataset.category;
                    
                    const matchesSearch = title.includes(searchTerm);
                    const matchesFilter = activeFilter === 'all' || category === activeFilter;

                    if (matchesSearch && matchesFilter) {
                        htmlElement.style.display = 'flex';
                    } else {
                        htmlElement.style.display = 'none';
                    }
                });
            }

            filterBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const target = e.currentTarget as HTMLElement;
                    
                    // Reset all buttons to inactive state
                    filterBtns.forEach(b => {
                        b.classList.remove('bg-darkBlue', 'text-white', 'active');
                        b.classList.add('bg-gray-50', 'text-gray-600');
                    });
                    
                    // Set clicked button to active state
                    target.classList.remove('bg-gray-50', 'text-gray-600');
                    target.classList.add('bg-darkBlue', 'text-white', 'active');
                    
                    // Trigger the filter function
                    filterCourses();
                });
            });

            // Listen for typing in the search bar
            if (searchInput) {
                searchInput.addEventListener('input', filterCourses);
            }
        });
    </script>
</BaseLayout>