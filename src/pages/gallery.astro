---
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch gallery items from Decap CMS. 
// We use a try/catch block so your site doesn't crash if you haven't uploaded any images yet!
let galleryItems = [];
try {
    galleryItems = await Astro.glob('../../gallery-data/*.md');
} catch (error) {
    galleryItems = [];
}

// Fallback dummy data so you can see the layout immediately before adding CMS content
const displayItems = galleryItems.length > 0 ? galleryItems.map(item => ({
    title: item.frontmatter.title,
    category: item.frontmatter.category,
    image: item.frontmatter.image
})) : [
    { title: "Annual Tech Fest", category: "Events", image: "https://placehold.co/600x600/e2e8f0/94a3b8?text=Placeholder" },
    { title: "Robotics Workshop", category: "Workshops", image: "https://placehold.co/600x600/e2e8f0/94a3b8?text=Placeholder" },
    { title: "Inter-University Basketball", category: "Sports", image: "https://placehold.co/600x600/e2e8f0/94a3b8?text=Placeholder" },
    { title: "Spring Music Festival", category: "Festivals", image: "https://placehold.co/600x600/e2e8f0/94a3b8?text=Placeholder" },
    { title: "AI Research Seminar", category: "Workshops", image: "https://placehold.co/600x600/e2e8f0/94a3b8?text=Placeholder" },
    { title: "Art & Design Exhibition", category: "Events", image: "https://placehold.co/600x600/e2e8f0/94a3b8?text=Placeholder" },
    { title: "Marathon for Cause", category: "Sports", image: "https://placehold.co/600x600/e2e8f0/94a3b8?text=Placeholder" },
    { title: "Global Alumni Meet", category: "Events", image: "https://placehold.co/600x600/e2e8f0/94a3b8?text=Placeholder" }
];

const categories = ['All', 'Events', 'Workshops', 'Sports', 'Festivals'];
---

<BaseLayout title="DoodleUni - Gallery">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        
        <!-- Hero Section -->
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h1 class="text-5xl font-bold text-darkBlue mb-6 tracking-tight">Campus Life in Frames</h1>
            <p class="text-lg text-gray-500 font-medium">
                A glimpse into the vibrant activities, events, and memories that make our university a home away from home.
            </p>
        </div>

        <!-- Filter Buttons -->
        <div class="flex flex-wrap justify-center gap-3 mb-12" id="filter-container">
            {categories.map((category, index) => (
                <button 
                    data-filter={category}
                    class={`px-6 py-2.5 rounded-full text-sm font-semibold transition-all duration-300 ${
                        index === 0 
                        ? 'bg-darkBlue text-white shadow-md' 
                        : 'bg-gray-50 text-gray-600 hover:bg-gray-100'
                    }`}
                >
                    {category}
                </button>
            ))}
        </div>

        <!-- Image Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10" id="gallery-grid">
            {displayItems.map((item) => (
                <div class="gallery-card group cursor-pointer" data-category={item.category}>
                    <div class="aspect-square overflow-hidden rounded-[2rem] mb-4 bg-gray-100 shadow-sm">
                        <img 
                            src={item.image} 
                            alt={item.title} 
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                            loading="lazy"
                        />
                    </div>
                    <div class="px-1">
                        <h3 class="text-lg font-bold text-darkBlue leading-tight mb-1">{item.title}</h3>
                        <p class="text-sm font-medium text-gray-400">{item.category}</p>
                    </div>
                </div>
            ))}
        </div>

    </div>
</BaseLayout>

<!-- Client-Side JavaScript for Filtering -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const buttons = document.querySelectorAll('#filter-container button');
        const cards = document.querySelectorAll('.gallery-card');

        buttons.forEach(button => {
            button.addEventListener('click', () => {
                // 1. Update button styling
                buttons.forEach(btn => {
                    btn.classList.remove('bg-darkBlue', 'text-white', 'shadow-md');
                    btn.classList.add('bg-gray-50', 'text-gray-600', 'hover:bg-gray-100');
                });
                button.classList.remove('bg-gray-50', 'text-gray-600', 'hover:bg-gray-100');
                button.classList.add('bg-darkBlue', 'text-white', 'shadow-md');

                // 2. Filter the grid items
                const selectedFilter = button.getAttribute('data-filter');

                cards.forEach(card => {
                    const cardCategory = card.getAttribute('data-category');
                    
                    if (selectedFilter === 'All' || selectedFilter === cardCategory) {
                        card.style.display = 'block';
                        // Add a tiny animation effect when items appear
                        card.animate([
                            { opacity: 0, transform: 'translateY(10px)' },
                            { opacity: 1, transform: 'translateY(0)' }
                        ], { duration: 300, easing: 'ease-out' });
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });
    });
</script>